```gitignore
# Dependencies
node_modules/

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
.coverage

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS generated files
.DS_Store
Thumbs.db

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# Build outputs
dist/
build/
*.out
*.exe
*.dll
*.so
*.a
*.obj

# Testing
.pytest_cache/
.mypy_cache/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```